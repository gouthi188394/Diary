{
  "name": "diary-saas",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "app/server",
    "app/web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "npm --workspace app/server run dev",
    "dev:web": "npm --workspace app/web run dev",
    "build": "npm-run-all build:server build:web",
    "build:server": "npm --workspace app/server run build",
    "build:web": "npm --workspace app/web run build",
    "test": "npm-run-all test:server test:web",
    "test:server": "npm --workspace app/server run test",
    "test:web": "npm --workspace app/web run test"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
